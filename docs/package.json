{
  "private": true,
  "type": "module",
  "scripts": {
    "docs:dev": "astro dev",
    "docs:build": "astro build",
    "docs:preview": "astro preview",
    "developer-docs:generate-openapi": "cargo test --manifest-path ../Cargo.toml --features openapi --test generate_openapi generate_openapi -- --exact",
    "developer-docs:prepare": "node scripts/prepare-developer-docs.mjs",
    "developer-docs:dev": "bun run developer-docs:generate-openapi && bun run developer-docs:prepare && astro dev --config astro.developer.config.mts",
    "developer-docs:build": "bun run developer-docs:generate-openapi && bun run developer-docs:prepare && astro build --config astro.developer.config.mts"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.3",
    "@astrojs/starlight": "^0.41.3",
    "astro": "^7.1.1",
    "sharp": "^0.35.3",
    "starlight-announcement": "^1.1.0",
    "starlight-copy-button": "github:dionysuzx/starlight-copy-button#d570fcab6824127f80076eb419f39fb4fbd9de09",
    "starlight-links-validator": "^0.25.2",
    "starlight-llms-txt": "^0.11.0",
    "starlight-openapi": "^0.26.0",
    "starlight-scroll-to-top": "^1.0.1"
  },
  "devDependencies": {
    "@beoe/rehype-mermaid": "^0.4.2",
    "astro-vtbot": "^3.0.0",
    "mermaid": "^11.16.0",
    "playwright": "^1.61.1"
  },
  "license": "MIT"
}
