---
import VtbotStarlight from 'astro-vtbot/components/starlight/Base.astro'

const openAPIBasePath = `${import.meta.env.BASE_URL.replace(/\/$/, '')}/openapi`
const isOpenAPIReference =
	Astro.url.pathname === openAPIBasePath || Astro.url.pathname.startsWith(`${openAPIBasePath}/`)
const head = isOpenAPIReference
	? Astro.locals.starlightRoute.head.filter(
			(entry) => !(entry.tag === 'link' && entry.attrs?.rel === 'alternate')
		)
	: Astro.locals.starlightRoute.head
---

<!--
  CSR 式软导航：ClientRouter + ReplacementSwap + StarlightConnector。
  Starlight 官方不支持 view transitions，这里用 astro-vtbot 的封装处理
  搜索/侧边栏当前页等状态在软导航后的重建。
-->
<VtbotStarlight>
	{head.map(({ tag: Tag, attrs, content }) => <Tag {...attrs} set:html={content} />)}
</VtbotStarlight>

<script>
	// Mermaid 点击缩放浮层
	function closeDiagramZoom() {
		document.querySelector('.aster-diagram-zoom')?.remove()
		document.body.classList.remove('aster-diagram-zoom-open')
	}

	function openDiagramZoom(event) {
		const target = event.target instanceof Element ? event.target : null
		const diagram = target?.closest('.sl-markdown-content .beoe.mermaid')
		if (!(diagram instanceof HTMLElement)) return

		// darkScheme: 'class' 会输出亮暗两份 SVG，取当前可见的那份
		const svgs = diagram.querySelectorAll('svg')
		const svg = [...svgs].find((node) => node.offsetParent !== null) ?? svgs[0]
		if (!svg) return

		const overlay = document.createElement('div')
		overlay.className = 'aster-diagram-zoom'
		overlay.setAttribute('role', 'dialog')
		overlay.setAttribute('aria-modal', 'true')

		const closeButton = document.createElement('button')
		closeButton.className = 'aster-diagram-zoom-close'
		closeButton.type = 'button'
		closeButton.setAttribute('aria-label', 'Close diagram zoom')
		closeButton.textContent = '×'
		closeButton.addEventListener('click', closeDiagramZoom)

		const canvas = document.createElement('div')
		canvas.className = 'aster-diagram-zoom-canvas'
		canvas.innerHTML = svg.outerHTML

		overlay.addEventListener('click', (clickEvent) => {
			if (clickEvent.target === overlay) closeDiagramZoom()
		})

		overlay.append(closeButton, canvas)
		document.body.append(overlay)
		document.body.classList.add('aster-diagram-zoom-open')
	}

	document.addEventListener('click', openDiagramZoom)
	document.addEventListener('keydown', (event) => {
		if (event.key === 'Escape') closeDiagramZoom()
	})

	// 首页（splash，无侧边栏框架）与文档页之间的跳转强制整页加载。
	// vtbot 的 ReplacementSwap 会保留侧边栏框架，跨过这条边界软导航会导致
	// 侧边栏不出现 / 不消失。站内其他软导航不受影响。
	function markBoundaryLinks() {
		const isSplash = !document.documentElement.hasAttribute('data-has-sidebar')
		document.querySelectorAll('a[href^="/"]').forEach((link) => {
			const href = link.getAttribute('href') ?? ''
			const toHome = ['/', '/en', '/en/', '/developer', '/developer/', '/developer/en', '/developer/en/'].includes(
				href
			)
			if (isSplash || toHome) {
				link.setAttribute('data-astro-reload', '')
			} else {
				link.removeAttribute('data-astro-reload')
			}
		})
	}
	document.addEventListener('astro:page-load', markBoundaryLinks)

	let announcementObserver: ResizeObserver | undefined
	function syncAnnouncementOffset() {
		announcementObserver?.disconnect()
		const announcements = document.querySelector('.sl-announcements-container')
		if (!(announcements instanceof HTMLElement)) {
			document.documentElement.style.setProperty('--aster-announcement-height', '0px')
			return
		}

		const updateHeight = () => {
			document.documentElement.style.setProperty(
				'--aster-announcement-height',
				`${announcements.getBoundingClientRect().height}px`
			)
		}

		announcementObserver = new ResizeObserver(updateHeight)
		announcementObserver.observe(announcements)
		updateHeight()
	}
	document.addEventListener('astro:page-load', syncAnnouncementOffset)
</script>
