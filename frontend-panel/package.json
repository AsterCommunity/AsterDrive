{
	"name": "asterdrive-panel",
	"private": true,
	"version": "0.4.0-beta.3",
	"author": "AptS:1547 <apts-1547@esaps.net>",
	"description": "The web-based control panel for AsterDrive",
	"license": "MIT",
	"type": "module",
	"scripts": {
		"extract:pdfjs-cmaps": "node ./scripts/extract-pdfjs-cmaps.mjs",
		"predev": "bun run extract:pdfjs-cmaps",
		"dev": "vite",
		"prebuild": "bun run extract:pdfjs-cmaps",
		"typecheck": "tsc -p tsconfig.app.json && tsc -p tsconfig.node.json",
		"build": "bun run typecheck && vite build",
		"postbuild": "node ./scripts/audit-startup.mjs",
		"generate-api": "openapi-typescript ./generated/openapi.json -o ./src/services/api.generated.ts",
		"check": "bun run typecheck && biome check .",
		"check:fix": "biome check --write .",
		"format": "biome format --write .",
		"preview": "vite preview",
		"test": "vitest run",
		"test:coverage": "vitest run --coverage",
		"test:watch": "vitest",
		"test:e2e": "playwright test",
		"test:e2e:asterdrive": "playwright test e2e",
		"test:e2e:headed": "playwright test --headed",
		"test:e2e:ui": "playwright test --ui"
	},
	"dependencies": {
		"@base-ui/react": "^1.6.0",
		"@fontsource-variable/geist": "^5.2.9",
		"@tailwindcss/typography": "^0.5.20",
		"@tailwindcss/vite": "^4.3.3",
		"@tanstack/react-virtual": "^3.14.6",
		"artplayer": "^5.4.0",
		"axios": "^1.18.1",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"i18next": "^26.3.6",
		"papaparse": "^5.5.4",
		"prism-react-renderer": "^2.4.1",
		"prismjs": "^1.30.0",
		"qrcode": "^1.5.4",
		"react": "^19.2.7",
		"react-devicons": "^2.16.2",
		"react-dom": "^19.2.7",
		"react-i18next": "^17.0.10",
		"react-icons": "^5.7.0",
		"react-image-crop": "^11.1.2",
		"react-markdown": "^10.1.0",
		"react-pdf": "^10.4.1",
		"react-router-dom": "^7.18.1",
		"recharts": "^3.9.2",
		"rehype-sanitize": "^6.0.0",
		"remark-gfm": "^4.0.1",
		"sonner": "^2.0.7",
		"tailwind-merge": "^3.6.0",
		"tailwindcss": "^4.3.3",
		"tw-animate-css": "^1.4.0",
		"xml-formatter": "^3.7.0",
		"zod": "^4.4.3",
		"zustand": "^5.0.14"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.4",
		"@playwright/test": "^1.61.1",
		"@testing-library/dom": "^10.4.1",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@testing-library/user-event": "^14.6.1",
		"@types/node": "^26.1.1",
		"@types/papaparse": "^5.5.2",
		"@types/qrcode": "^1.5.6",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.3",
		"@vitest/coverage-v8": "^4.1.10",
		"jsdom": "^29.1.1",
		"msw": "^2.15.0",
		"openapi-typescript": "^7.13.0",
		"shadcn": "^4.13.1",
		"typescript": "^7.0.2",
		"vite": "^8.1.5",
		"vite-plugin-pwa": "^1.3.0",
		"vitest": "^4.1.10"
	},
	"overrides": {
		"@babel/plugin-transform-modules-systemjs": "7.29.4",
		"@hono/node-server": "2.0.3",
		"brace-expansion": "5.0.6",
		"fast-uri": "3.1.2",
		"form-data": "4.0.6",
		"hono": "4.12.25",
		"ip-address": "10.2.0",
		"picomatch": "4.0.4",
		"react": "^19.2.7",
		"undici": "7.28.0"
	},
	"optionalDependencies": {
		"@rolldown/binding-linux-x64-musl": "1.2.0"
	}
}
